						<key>Title</key>
						<string>Set Piano Roll Command-Click Tool</string>
					</dict>
					<dict>
						<key>ActionUID</key>
						<integer>9679898</integer>
						<key>DisplayKind</key>
						<string>None</string>
						<key>HonourFailureSettings</key>
						<true/>
						<key>IncludeStdErr</key>
